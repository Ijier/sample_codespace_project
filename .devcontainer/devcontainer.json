{
  "name": "Full Stack Dev Environment",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "features": {
    // これだけで docker と docker-compose が使えるようになります
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest"
    }
  },
  // 起動時にサブモジュールを自動展開
  "postCreateCommand": "git submodule update --init --recursive",
  // 開発中に使うポートを自動でフォワード
  "forwardPorts": [3000, 8000, 5432], 
  "remoteUser": "vscode",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-azuretools.vscode-docker" // Docker管理を便利にする拡張
      ]
    }
  }
}